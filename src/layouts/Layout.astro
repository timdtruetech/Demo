---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Northline — Digital Marketing That Moves the Needle",
  description = "Northline runs paid, content, and lifecycle campaigns for growth-stage brands, and reports the line going up in plain numbers.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <slot />
  </body>
</html>
