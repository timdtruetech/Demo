---
---

<section class="hero" id="top">
  <div class="wrap hero-grid">
    <div class="hero-copy">
      <p class="eyebrow tag">Digital marketing, plotted honestly</p>
      <h1>
        Marketing that moves the needle —
        <span class="accent">visibly, weekly, provably.</span>
      </h1>
      <p class="lede">
        Northline plans, builds, and runs paid, content, and lifecycle
        campaigns for growth-stage brands. Every Friday you get one line
        going up, with the numbers behind it, not a slide deck of vanity
        metrics.
      </p>
      <div class="hero-actions">
        <a href="#contact" class="btn-primary">Book a strategy call</a>
        <a href="#about" class="btn-ghost">See how we work</a>
      </div>
      <dl class="proof">
        <div>
          <dt>Avg. ROAS across active accounts</dt>
          <dd>3.4×</dd>
        </div>
        <div>
          <dt>Campaigns launched to date</dt>
          <dd>212</dd>
        </div>
        <div>
          <dt>Median time to first result</dt>
          <dd>18 days</dd>
        </div>
      </dl>
    </div>

    <div class="hero-visual" aria-hidden="true">
      <svg class="growth-svg" viewBox="0 0 420 320" fill="none">
        <line x1="20" y1="40" x2="20" y2="280" stroke="var(--line)" stroke-width="1"/>
        <line x1="20" y1="280" x2="400" y2="280" stroke="var(--line)" stroke-width="1"/>
        <path
          class="growth-path"
          d="M20 240 C 70 250, 90 200, 130 205 C 170 210, 175 150, 220 140 C 260 132, 270 90, 310 70 C 340 56, 355 55, 396 30"
          stroke="var(--lime)"
          stroke-width="3"
          stroke-linecap="round"
        />
        <circle class="growth-dot" cx="396" cy="30" r="5" fill="var(--lime)"/>
        <text x="332" y="20" class="growth-label">this quarter</text>
        <text x="24" y="300" class="axis-label">Q1</text>
        <text x="370" y="300" class="axis-label">Q4</text>
      </svg>
      <p class="visual-caption">One dashboard. One line. Your traffic, leads, or revenue — your call.</p>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-block: clamp(3rem, 8vw, 6rem) clamp(3.5rem, 8vw, 6.5rem);
    border-bottom: 1px solid var(--line);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: center;
  }

  .tag {
    color: var(--lime);
    margin-bottom: 1.1rem;
  }

  h1 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.3rem, 4.6vw, 3.6rem);
    line-height: 1.06;
    letter-spacing: -0.015em;
    color: var(--text-on-ink);
  }

  h1 .accent {
    font-style: italic;
    font-weight: 500;
    color: var(--lime);
  }

  .lede {
    margin-top: 1.4rem;
    max-width: 46ch;
    color: var(--text-on-ink-dim);
    font-size: 1.06rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.9rem;
    margin-top: 2.1rem;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--lime);
    color: var(--ink);
    padding: 0.85rem 1.5rem;
    border-radius: 999px;
    font-weight: 600;
    font-size: 0.95rem;
    transition: transform 0.15s ease;
  }

  .btn-primary:hover, .btn-primary:focus-visible {
    transform: translateY(-2px);
  }

  .btn-ghost {
    padding: 0.85rem 1.4rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    color: var(--text-on-ink-dim);
    font-size: 0.95rem;
    transition: border-color 0.15s ease, color 0.15s ease;
  }

  .btn-ghost:hover, .btn-ghost:focus-visible {
    border-color: var(--text-on-ink);
    color: var(--text-on-ink);
  }

  .proof {
    display: grid;
    grid-template-columns: repeat(3, auto);
    gap: 1.8rem;
    margin-top: 2.8rem;
    padding-top: 1.8rem;
    border-top: 1px solid var(--line);
  }

  .proof dt {
    font-size: 0.74rem;
    color: var(--text-on-ink-dim);
    max-width: 16ch;
    line-height: 1.3;
  }

  .proof dd {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    color: var(--text-on-ink);
    margin-top: 0.35rem;
  }

  .hero-visual {
    position: relative;
  }

  .growth-svg {
    width: 100%;
    height: auto;
  }

  .growth-path {
    stroke-dasharray: 520;
    stroke-dashoffset: 520;
    animation: draw 1.8s ease-out 0.2s forwards;
  }

  .growth-dot {
    opacity: 0;
    animation: pop 0.4s ease-out 1.9s forwards;
  }

  .growth-label {
    font-family: var(--font-mono);
    font-size: 10px;
    fill: var(--text-on-ink-dim);
    opacity: 0;
    animation: pop 0.4s ease-out 2s forwards;
  }

  .axis-label {
    font-family: var(--font-mono);
    font-size: 10px;
    fill: var(--text-on-ink-dim);
  }

  @keyframes draw {
    to { stroke-dashoffset: 0; }
  }

  @keyframes pop {
    to { opacity: 1; }
  }

  .visual-caption {
    margin-top: 1rem;
    font-size: 0.85rem;
    color: var(--text-on-ink-dim);
    text-align: center;
  }

  @media (prefers-reduced-motion: reduce) {
    .growth-path { stroke-dashoffset: 0; animation: none; }
    .growth-dot, .growth-label { opacity: 1; animation: none; }
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
    .proof {
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }
  }

  @media (max-width: 520px) {
    .proof { grid-template-columns: 1fr 1fr; }
  }
</style>
